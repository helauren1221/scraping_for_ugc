# Meta Marketing API credentials
# Add these to a .env file (never commit .env to git)
META_ACCESS_TOKEN=your-user-or-system-user-token
META_AD_ACCOUNT_ID=act_XXXXXXXXX
META_APP_ID=your-app-id
META_APP_SECRET=your-app-secret

# Optional: date range for insights (default: last_7d)
# Options: last_7d, last_14d, last_30d, this_week_sun_today, last_week_sun_sat
META_DATE_PRESET=last_7d

# Optional: API version (default: v21.0)
META_API_VERSION=v21.0

# Trello integration (optional — needed for --trello flag)
# Get your key + token at: https://trello.com/power-ups/admin
# Board ID is the short code in your board URL: trello.com/b/BOARD_ID/...
TRELLO_API_KEY=your-trello-api-key
TRELLO_TOKEN=your-trello-token
TRELLO_BOARD_ID=your-board-id
